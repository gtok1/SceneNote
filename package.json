{
  "name": "scenenote",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "restart": "pkill -f \"expo start\" || true; expo start --port 8081 --localhost --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:restart": "pkill -f \"expo start\" || true; expo start --web --port 8081 --localhost --clear",
    "dev:restart": "pkill -f \"expo start\" || true; pkill -f \"supabase functions serve\" || true; npm run backend:serve & EXPO_NO_TELEMETRY=1 expo start --web --port 8081 --localhost --clear",
    "backend:serve": "supabase functions serve --env-file .env",
    "backend:deploy": "supabase functions deploy search-content add-to-library get-content-detail get-watch-providers fetch-episodes bulk-register-netflix",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "tsx --test src/**/*.test.ts scripts/**/*.test.ts supabase/functions/**/*.test.ts",
    "import:netflix": "tsx scripts/import-netflix-tmdb-bulk.ts",
    "smoke:edge": "tsx scripts/smoke-edge-functions.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.0",
    "@hookform/resolvers": "^3.9.0",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.59.0",
    "expo": "^54.0.0",
    "expo-constants": "^18.0.0",
    "expo-document-picker": "~14.0.8",
    "expo-image": "^3.0.0",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "^8.0.0",
    "expo-router": "^6.0.0",
    "expo-secure-store": "^15.0.0",
    "expo-status-bar": "^3.0.0",
    "jotai": "^2.19.1",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.53.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.2",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
